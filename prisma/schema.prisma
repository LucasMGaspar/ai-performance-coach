generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id              String    @id @default(cuid())
  phoneNumber     String    @unique
  name            String?
  height          Float?
  weightKg        Float?
  age             Int?
  sex             String? // "masculino" | "feminino"
  experienceLevel String? // "iniciante" | "intermédio" | "avançado"
  goal            String? // "hipertrofia" | "emagrecimento" | etc
  onboarded       Boolean   @default(false)
  role            Role      @default(USER)
  streakCount     Int       @default(0)
  maxStreak       Int       @default(0)
  lastLogAt       DateTime?
  tdee            Float?
  targetCalories  Float?
  targetProtein   Float?
  consistencyScore Int      @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workoutLogs    WorkoutLog[]
  dietLogs       DietLog[]
  checkIns       DailyCheckIn[]
  scheduledMeals ScheduledMeal[]
  prs            ExercisePR[]
  insights       UserInsight[]

  @@map("users")
}

model ExercisePR {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  weightKg   Float
  reps       Int
  e1rmKg     Float?
  date       DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id])
  exercise ExerciseCatalog @relation(fields: [exerciseId], references: [id])

  @@unique([userId, exerciseId])
  @@map("exercise_prs")
}

model ScheduledMeal {
  id             String @id @default(cuid())
  userId         String
  mealName       String // "Pequeno-almoço", "Almoço", etc
  scheduledTime  String // "08:00"
  description    String
  targetCalories Float
  targetProtein  Float
  targetCarbs    Float?
  targetFat      Float?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("scheduled_meals")
}

model ExerciseCatalog {
  id          String   @id @default(cuid())
  name        String   @unique
  aliases     String[]
  muscleGroup String
  equipment   String?
  barWeightKg Float?

  workoutLogs WorkoutLog[]
  exercisePRs ExercisePR[]

  @@map("exercise_catalog")
}

model WorkoutLog {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  date       DateTime @default(now())
  weightKg   Float
  reps       Int
  sets       Int
  rpe        Float?
  volume     Float
  rawInput   String?

  user     User            @relation(fields: [userId], references: [id])
  exercise ExerciseCatalog @relation(fields: [exerciseId], references: [id])

  @@index([userId, exerciseId, date])
  @@map("workout_logs")
}

model DietLog {
  id       String   @id @default(cuid())
  userId   String
  meal     String
  calories Float
  protein  Float
  carbs    Float?
  fat      Float?
  date     DateTime @default(now())
  notes    String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("diet_logs")
}

model DailyCheckIn {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @default(now())
  mood         Int
  sleepQuality Int
  energyLevel  Int
  notes        String?
  waterLiters  Float    @default(0)
  supplements  String[] @default([])

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("daily_checkins")
}

model UserInsight {
  id        String   @id @default(cuid())
  userId    String
  type      String
  content   String
  evidence  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type, active])
  @@map("user_insights")
}
